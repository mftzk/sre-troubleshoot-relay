# 9Router (OpenAI-compatible) — endpoint must be reachable from the deployed app
OPENAI_BASE_URL=https://your-9router-host/v1
OPENAI_API_KEY=sk-your-9router-key
LLM_MODEL=gpt-4o-mini

# Gameplay
MAX_ATTEMPTS=3

# Database — injected automatically by nrapken when a DB is attached.
# For local dev, set your own Postgres connection string:
DATABASE_URL=postgres://user:pass@localhost:5432/sre_game
# Set to "true" if your Postgres requires SSL (managed DBs often do):
DB_SSL=false
